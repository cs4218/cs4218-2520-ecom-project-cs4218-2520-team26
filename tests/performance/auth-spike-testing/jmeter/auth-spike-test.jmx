      <!-- ============================================================ -->
      <!-- TG5: Phase 5 - Post-Spike Observation                        -->
      <!-- Steady baseline load after full recovery. Confirms the       -->
      <!-- system has returned to pre-spike performance levels.         -->
      <!-- Delay: BASELINE_SEC + SPIKE_TRIGGER_SEC + SPIKE_HOLD_SEC    -->
      <!--        + RECOVERY_SEC                                        -->
      <!-- ============================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Phase 5 - Post-Spike Observation">
        <stringProp name="ThreadGroup.num_threads">${BASELINE_USERS}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${BASELINE_RAMP_SECONDS}</stringProp>
        <stringProp name="ThreadGroup.duration">${POST_SPIKE_SEC}</stringProp>
        <stringProp name="ThreadGroup.delay">${__intSum(${BASELINE_SEC},${SPIKE_TRIGGER_SEC},${SPIKE_HOLD_SEC},${RECOVERY_SEC})}</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <intProp name="LoopController.loops">-1</intProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
